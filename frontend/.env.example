# ================================================================
# Bank Transaction System — Frontend Environment Variables
# Copy this file to frontend/.env and fill in real values.
# NEVER commit the .env file to version control.
# ================================================================

# Base URL of your backend API.
# LOCAL DEV: Leave as http://localhost:3000 — vite.config.js proxy forwards /api/*.
# PRODUCTION (Vercel): Set to your Render backend URL, e.g.:
#   VITE_API_BASE_URL=https://bank-txn-backend.onrender.com
VITE_API_BASE_URL=http://localhost:3000

# Set to "true" to reveal a demo login shortcut on the login page.
# Uses accounts seeded by `npm run seed` on the backend.
# NEVER enable in production.
VITE_ALLOW_DEMO=false

# Set to "true" to globally disable 3D/parallax animations
# (useful for performance testing or CI screenshot runners).
VITE_DISABLE_ANIMATIONS=false

# Set to "true" to send withCredentials on all axios requests (httpOnly cookie auth).
# IMPORTANT: For cross-origin deployments (Vercel frontend → Render backend), this
# MUST be "false". The backend returns the JWT in the response body; the frontend
# stores it in localStorage and sends it as a Bearer token.
# Only set to "true" if frontend and backend are on the SAME domain.
VITE_USE_COOKIE_AUTH=false
